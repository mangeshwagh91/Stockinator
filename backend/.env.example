# Application
APP_NAME=Stockinator
DEBUG=True
API_V1_PREFIX=/api/v1

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stockinator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# InfluxDB
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influx-token
INFLUX_ORG=stockinator
INFLUX_BUCKET=market_data

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenAI (for LLM sentiment)
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4

# News API
NEWS_API_KEY=your-news-api-key

# Broker APIs
ALPACA_API_KEY=your-alpaca-key
ALPACA_SECRET_KEY=your-alpaca-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
UPSTOX_API_KEY=your-upstox-api-key
UPSTOX_SECRET_KEY=your-upstox-secret-key
UPSTOX_ACCESS_TOKEN=your-upstox-access-token
UPSTOX_API_URL=https://api.upstox.com/v2

# Trading Settings
PAPER_TRADING=True
DEFAULT_THRESHOLD=80
COOLDOWN_MINUTES=30
MAX_DAILY_LOSS=5000
MAX_POSITION_SIZE=10000

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
